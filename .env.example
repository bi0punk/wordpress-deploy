# ===== Wordpress-deploy .env.example =====
# Copia a .env y completa los valores reales:  cp .env.example .env

# Zona horaria
TZ=America/Santiago

# MariaDB
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=cambia_esta_password
MYSQL_ROOT_PASSWORD=cambia_esta_root_password

# WordPress
WP_HOME_URL=http://localhost:8080
WORDPRESS_TABLE_PREFIX=wp_

# Redis (object cache). La red interna de Docker ya aísla Redis del host;
# además requiere esta password. Usá una password fuerte en producción.
REDIS_PASSWORD=cambia_esta_redis_password
